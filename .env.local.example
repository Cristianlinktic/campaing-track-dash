# ──────────────────────────────────────────────────────────────
# Supabase — copia este archivo a .env.local y rellena los valores.
# Project Settings → API en tu panel de Supabase.
# ──────────────────────────────────────────────────────────────

# URL pública del proyecto (https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Service role key — SOLO se usa en el servidor (server components, API routes,
# server actions). NUNCA se expone al navegador. Permite saltar RLS de forma segura.
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────────────────────────────
# Autenticación
# ──────────────────────────────────────────────────────────────

# Secreto para firmar el JWT de sesión. Genera uno con:
#   openssl rand -base64 48
AUTH_SECRET=
